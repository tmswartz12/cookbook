# dependencies
node_modules/

# env / secrets
.env
.env.local
.env.*.local

# build output
dist/
*.tsbuildinfo
# NOTE: the bundled serverless function api/[...path].js IS committed on purpose
# — Vercel detects functions from the committed api/ dir before the build runs,
# so a build-time-generated file would never be registered. Regenerate it with
# `npm run build:api` and commit the result whenever the server/ source changes.

# vercel
.vercel/

# editor / os
.DS_Store
*.log
