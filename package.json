{
  "name": "cookbook",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A shared cookbook for Tyler & Sarah — photo-forward recipes, public by link, editable by two.",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx watch --env-file=.env server/dev-server.ts",
    "dev:all": "concurrently -n api,web -c green,cyan \"npm:dev:api\" \"npm:dev\"",
    "dev:vercel": "vercel dev",
    "build": "tsc -b && vite build && npm run build:api",
    "build:api": "node scripts/build-api.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "seed": "tsx --env-file=.env server/seed.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.51.0",
    "axios": "^1.7.0",
    "cloudinary": "^2.4.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "google-auth-library": "^9.14.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.1",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
