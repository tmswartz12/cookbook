# ---------- Backend / serverless (.env) ----------
# MongoDB Atlas SRV connection string
MONGODB_URI=
# Long random string used to sign app JWTs (e.g. `openssl rand -hex 32`)
JWT_SECRET=
# Google OAuth 2.0 Web Client ID (same value as VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=
# Comma-separated allowlist of editor emails
EDITOR_EMAILS=tyler@example.com,sarah@example.com
# Cloudinary credentials
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Allowed browser origin for CORS (prod: your Vercel URL)
CLIENT_ORIGIN=http://localhost:5173
NODE_ENV=development

# ---------- Frontend (Vite — these are PUBLIC, must be VITE_-prefixed) ----------
VITE_GOOGLE_CLIENT_ID=
VITE_CLOUDINARY_CLOUD_NAME=
# Same-origin in the Vercel monorepo; only change for the Render/Railway fallback
VITE_API_URL=/api
